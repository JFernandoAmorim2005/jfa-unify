#!/bin/bash

# JFA Unify Deployment Script (Production)
# Usage: ./deploy-unify [--env production|staging] [--skip-tests] [--rollback]

set -e

# Configuration
DEPLOY_ENV="${1:--env}"
ENV_NAME="${2:-production}"
SKIP_TESTS="${3:---skip-tests}"
DEPLOY_HOST="${DEPLOY_HOST:-ubuntu-50.jfernandoamorim.com}"
DEPLOY_USER="${DEPLOY_USER:-ubuntu}"
DEPLOY_PATH="/opt/jfa/unify"
DOCKER_REGISTRY="${DOCKER_REGISTRY:-registry.jfernandoamorim.com}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${GREEN}=== JFA Unify Deployment ===${NC}"
echo "Environment: $ENV_NAME"
echo "Host: $DEPLOY_HOST"

# Step 1: Pre-deployment checks
echo -e "${YELLOW}[1/8] Pre-deployment checks...${NC}"
if [ ! -f ".env.$ENV_NAME" ]; then
    echo -e "${RED}ERROR: .env.$ENV_NAME not found${NC}"
    exit 1
fi

# Step 2: Run tests (unless skipped)
if [ "$SKIP_TESTS" != "--skip-tests" ]; then
    echo -e "${YELLOW}[2/8] Running tests...${NC}"
    cd backend
    python -m pytest -q --tb=short
    cd ..
fi

# Step 3: Build Docker images
echo -e "${YELLOW}[3/8] Building Docker images...${NC}"
docker build -f backend/Dockerfile.prod -t "$DOCKER_REGISTRY/jfa-unify-backend:latest" ./backend
docker build -f frontend/Dockerfile.prod -t "$DOCKER_REGISTRY/jfa-unify-frontend:latest" ./frontend

# Step 4: Push to registry (if configured)
if [ -n "$DOCKER_REGISTRY" ] && [ "$DOCKER_REGISTRY" != "local" ]; then
    echo -e "${YELLOW}[4/8] Pushing images to registry...${NC}"
    docker push "$DOCKER_REGISTRY/jfa-unify-backend:latest"
    docker push "$DOCKER_REGISTRY/jfa-unify-frontend:latest"
fi

# Step 5: Create backup
echo -e "${YELLOW}[5/8] Creating backup...${NC}"
ssh "$DEPLOY_USER@$DEPLOY_HOST" "cd $DEPLOY_PATH && docker-compose exec -T postgres pg_dump -U \$DB_USER jfa_unify > backup/db_\$(date +%Y%m%d_%H%M%S).sql"

# Step 6: Stop current deployment
echo -e "${YELLOW}[6/8] Stopping current deployment...${NC}"
ssh "$DEPLOY_USER@$DEPLOY_HOST" "cd $DEPLOY_PATH && docker-compose down"

# Step 7: Pull latest code and redeploy
echo -e "${YELLOW}[7/8] Deploying new version...${NC}"
ssh "$DEPLOY_USER@$DEPLOY_HOST" "cd $DEPLOY_PATH && git pull origin main && docker-compose -f docker-compose.prod.yml up -d"

# Step 8: Verify deployment
echo -e "${YELLOW}[8/8] Verifying deployment...${NC}"
sleep 10
if ssh "$DEPLOY_USER@$DEPLOY_HOST" "curl -s -f http://localhost:8000/health > /dev/null"; then
    echo -e "${GREEN}✅ Deployment successful!${NC}"
    echo "Backend: http://$DEPLOY_HOST:8000"
    echo "Frontend: http://$DEPLOY_HOST:3000"
else
    echo -e "${RED}❌ Deployment verification failed${NC}"
    echo "Rolling back..."
    ssh "$DEPLOY_USER@$DEPLOY_HOST" "cd $DEPLOY_PATH && git revert HEAD && docker-compose -f docker-compose.prod.yml up -d"
    exit 1
fi
