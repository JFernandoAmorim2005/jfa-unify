# /opt/jfa-unify/.env — PRODUÇÃO
# Copiar para /opt/jfa-unify/.env no servidor e preencher todos os valores.
# NUNCA commitar este ficheiro com valores reais.

# --- PostgreSQL (container unify-postgres) ---
POSTGRES_USER=jfaunify
POSTGRES_PASSWORD=PREENCHER-password-forte-32-chars-min
POSTGRES_DB=jfaunify
POSTGRES_APP_USER_PASSWORD=PREENCHER-app-user-password-diferente

# --- Base de Dados (app) ---
DATABASE_URL=postgresql://jfaunify:PREENCHER-password-forte-32-chars-min@postgres:5432/jfaunify

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- MQTT ---
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_TLS_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=jfaunify-api

# --- Segurança ---
SECRET_KEY=PREENCHER-32-chars-random-python-secrets-token-hex-32
HMAC_ALGORITHM=sha256
TOKEN_EXPIRY_SECONDS=3600

# --- Tuya Hub (se mqtt_adapter_type=tuya) ---
TUYA_HUB_TOPIC_PREFIX=tuya/
TUYA_ACCESS_ID=PREENCHER
TUYA_ACCESS_SECRET=PREENCHER

# --- Suite Integration (desactivado por defeito) ---
SUITE_INTEGRATION_ENABLED=false
SUITE_BASE_URL=http://localhost:8040
SUITE_API_TOKEN=

# --- Ambiente ---
ENVIRONMENT=production
LOG_LEVEL=INFO
