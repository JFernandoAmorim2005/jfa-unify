# Configuração PostgreSQL para testes RLS integration

# Superuser (bypassa RLS) — para setup/teardown
POSTGRES_USER=postgres
POSTGRES_PASSWORD=test-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=jfa_test

# App user (respeita RLS) — para testes
APP_USER=app_user
APP_PASSWORD=test-app-password

# Flask/SQLAlchemy
DATABASE_URL=postgresql://postgres:test-password@localhost:5433/jfa_test
TESTING=0

# Logging
LOG_LEVEL=INFO
