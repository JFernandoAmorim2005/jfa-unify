# --- Base de Dados ---
DATABASE_URL=postgresql://jfaunify:devpassword123@localhost:5432/jfaunify_db

# --- Broker MQTT ---
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TLS_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=jfaunify-api

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Segurança ---
SECRET_KEY=change-me-in-production-must-be-32-chars-min
HMAC_ALGORITHM=sha256
TOKEN_EXPIRY_SECONDS=3600

# --- Tuya Hub ---
TUYA_HUB_TOPIC_PREFIX=tuya/
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=

# --- Ambiente ---
ENVIRONMENT=development
LOG_LEVEL=DEBUG
